# ─── Database ─────────────────────────────────────────────────────────────────
# asyncpg connection string for PostgreSQL.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# When running via Docker Compose, host is the service name ("postgres").
DATABASE_URL=postgresql+asyncpg://spent:spent@postgres:5432/spent

# ─── Anthropic AI (Phase 3) ───────────────────────────────────────────────────
# Your Anthropic API key for Claude-powered expense categorization.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Telegram Bot (Phase 2) ───────────────────────────────────────────────────
# Token for your Telegram bot, obtained from @BotFather.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─── AI Settings (Phase 3) ────────────────────────────────────────────────────
# Minimum confidence score (0.0–1.0) for AI categorization to be accepted.
# Below this threshold, the category defaults to "other".
AI_CONFIDENCE_THRESHOLD=0.75

# ─── App Settings ─────────────────────────────────────────────────────────────
# Set to "production" when deploying. Affects logging verbosity and SQL echo.
ENVIRONMENT=development
